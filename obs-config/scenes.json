            "height": 1080,
            "crop": {
              "top": 0,
              "bottom": 0,
              "left": 0,
              "right": 0
            }
          },
          "z_order": 0
        },
        {
          "name": "残局挑战覆层 Puzzle Overlay",
          "type": "browser_source",
          "description": "Puzzle challenge overlay with countdown, difficulty badge, and hints",
          "url": "file:///Users/changchunshi/codebase/chess/overlays/puzzle-challenge.html",
          "parameters": {
            "example_url": "file:///Users/changchunshi/codebase/chess/overlays/puzzle-challenge.html?time=60&difficulty=hard"
