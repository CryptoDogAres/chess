    {
      "name": "竖屏短视频 Vertical Short",
      "id": "vertical-short",
      "use_case": "Douyin/YouTube Shorts vertical recording (9:16)",
      "profile": "vertical",
      "canvas": {
        "width": 1080,
        "height": 1920
      },
      "sources": [
        {
          "name": "棋盘窗口 Board Window (裁剪)",
          "type": "window_capture",
          "description": "Browser window cropped to square and centered vertically",
          "target_windows": [
            "board.html",
            "board-art.html"
          ],
          "transform": {
            "x": 0,
            "y": 420,
            "width": 1080,
            "height": 1080
          },
          "crop_notes": "Crop the window capture to a 1:1 square showing only the board. Use Edit Transform (Ctrl+E on the source) to set crop values. Center vertically at y=420 to leave 420px above and below for text/branding.",
          "z_order": 0
        },
        {
          "name": "麦克风 Microphone",
          "type": "audio_input_capture",
          "description": "Microphone for short-form voiceover",
          "settings": {
            "device": "default"
          },
          "z_order": 1
        }
      ],
      "recording_settings": {
        "format": "mp4",
        "encoder": "x264",
        "rate_control": "CBR",
        "bitrate_kbps": 6000,
        "max_duration_seconds": 60,
        "notes": "Keep videos under 60 seconds for Shorts. Use vertical profile (1080x1920)."
      },
      "notes": "Switch to the vertical profile before using this scene. Board centered as a square in the middle of the vertical canvas. Top and bottom areas (420px each) can be used for text overlays added in post-production."
    }
  ],
  "global_settings": {
    "video": {
      "base_resolution_landscape": "1920x1080",
      "base_resolution_vertical": "1080x1920",
      "output_resolution_landscape": "1920x1080",
      "output_resolution_vertical": "1080x1920",
      "fps": 30,
      "color_format": "NV12",
      "color_space": "709",
      "color_range": "Partial"
    },
    "output": {
      "mode": "Advanced",
      "recording": {
        "encoder": "x264",
        "rate_control": "CBR",
        "bitrate_kbps": 6000,
        "keyframe_interval": 2,
        "cpu_preset": "medium",
        "profile": "high",
        "format": "mkv",
        "notes": "Record in MKV for crash safety, remux to MP4 via File → Remux Recordings after recording."
      },
      "streaming": {
        "encoder": "x264",
        "rate_control": "CBR",
        "bitrate_kbps": 6000,
        "keyframe_interval": 2,
        "cpu_preset": "veryfast",
        "profile": "high"
      }
    },
    "audio": {
      "sample_rate": 48000,
      "channels": "Stereo",
      "audio_bitrate_kbps": 160,
      "codec": "AAC"
    }
