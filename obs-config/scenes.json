{
  "description": "OBS Studio scene configurations for Chinese Chess content creation",
  "version": "1.0",
  "project_root": "/Users/changchunshi/codebase/chess",
  "overlay_base_url": "file:///Users/changchunshi/codebase/chess/overlays",
  "scenes": [
    {
      "name": "棋局分析 Board Analysis",
      "id": "board-analysis",
      "use_case": "Pre-recorded puzzle and game analysis videos",
      "profile": "landscape",
      "canvas": {
        "width": 1920,
        "height": 1080
      },
      "sources": [
        {
          "name": "棋盘窗口 Board Window",
          "type": "window_capture",
          "description": "Browser window showing board-art.html or explain.html",
          "target_windows": [
            "board-art.html",
            "explain.html"
          ],
          "transform": {
            "x": 0,
            "y": 0,
            "width": 1920,
            "height": 1080,
            "crop": {
              "top": 0,
              "bottom": 0,
              "left": 0,
              "right": 0
            }
          },
          "z_order": 0
        },
        {
          "name": "麦克风 Microphone",
          "type": "audio_input_capture",
          "description": "Microphone for voice commentary",
          "settings": {
            "device": "default",
            "filters": [
              {
                "type": "noise_suppress",
                "method": "rnnoise"
              },
              {
                "type": "compressor",
                "ratio": 3,
                "threshold_db": -18
              }
            ]
          },
          "z_order": 1
        }
      ],
      "notes": "Full-screen capture of the analysis board. Use board-art.html for artistic presentations or explain.html for annotated analysis."
    },
    {
      "name": "残局挑战 Puzzle Challenge",
      "id": "puzzle-challenge",
